# =====================================================================
# Alexandria MCP Server — Hub de Contexto Semântico (Totum OS)
# =====================================================================
# Copie este arquivo para `.env` e preencha. NUNCA commitar `.env`.
# Decisões: D-017 (127.0.0.1 explícito), D-021 (secrets via SSH).

# ---- Transport ------------------------------------------------------
# stdio (default, agentes locais) ou sse (rede / totum-system)
MCP_TRANSPORT=stdio
# Porta para o servidor SSE (só usado se MCP_TRANSPORT=sse)
MCP_SSE_PORT=4317
# Host SSE (D-017: sempre 127.0.0.1 em loopback)
MCP_SSE_HOST=127.0.0.1

# ---- Supabase (cgpkfhrqprqptvehatad) --------------------------------
# RLS: leitura authenticated, escrita só com SERVICE_ROLE (schema doc §5).
SUPABASE_URL=https://cgpkfhrqprqptvehatad.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Threshold cosine para RPCs match_documents/search_docs/search_pops/search_skills.
# 0.7 é o default das funções; menor = mais similar.
SUPABASE_KNOWLEDGE_THRESHOLD=0.7

# ---- Embeddings (CLIENT-SIDE — generate_embedding do banco é stub!) -
# Schema doc §A: generate_embedding(text) NO BANCO retorna NULL.
# Sempre gerar aqui e passar o vetor pras RPCs.
# Dimensão: 768 (giles/alexandria/hermione base). NÃO usar 1536 (rag_documents morta).
# M134: text-embedding-004 deprecado → gemini-embedding-001 @ outputDimensionality=768.
#
# Dois providers reais (escolha por EMBEDDING_PROVIDER):
#  (1) google  — gemini-embedding-001 @ 768d (precisa EMBEDDING_API_KEY)
#  (2) ollama  — nomic-embed-text @ 768d, local na VPS (loopback, zero custo, ~0.5-0.8s/doc)
#      M134-C: Ollama v0.30.6 systemd em 127.0.0.1:11434; reindex 657 ~5.5-9min.
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
EMBEDDING_API_KEY=
# Modo Ollama (VPS): EMBEDDING_PROVIDER=ollama · EMBEDDING_MODEL=nomic-embed-text
OLLAMA_URL=http://127.0.0.1:11434
# Em dev/teste, EMBEDDING_PROVIDER=stub gera vetores determinísticos sem API.
# TODO(M79): confirmar com app Alexandria o encoder real que popula giles_knowledge.

# ---- Keycloak (Auth M2M) --------------------------------------------
# Em dev, KEYCLOAK_BYPASS=true desliga validação JWT (usar só local).
KEYCLOAK_BYPASS=true
KEYCLOAK_ISSUER_URL=http://127.0.0.1:8180/realms/totum
KEYCLOAK_INTROSPECT_URL=http://127.0.0.1:8180/realms/totum/protocol/openid-connect/token/introspect
# Credenciais dos clients (vir do /home/totum/.pepper/.env via Rael).
# TODO(M75): confirmar nomes exatos das variáveis na VPS.
KC_CLIENT_MCP_READ_ID=alexandria-mcp-read
KC_CLIENT_MCP_READ_SECRET=
KC_CLIENT_ADMIN_ID=alexandria-admin
KC_CLIENT_ADMIN_SECRET=

# ---- Caminhos do repo (resolvidos a partir do root Alexandria) -----
# Os 4 artefatos de orquestração ficam no root do repo Alexandria.
# REPO_ROOT é detectado automaticamente; só sobrescreva se a estrutura mudar.
# REPO_ROOT=/Users/israellemos/Documents/Pixel Systems/Alexandria

# ---- Legacy bridge (mantém compat com server.mjs antigo) ------------
# Quando definido, as 3 tools legadas (alexandria_search, _get_artifact,
# _context_pack) fazem proxy HTTP para esse endpoint.
ALEXANDRIA_MCP_URL=
ALEXANDRIA_MCP_TOKEN=

# ---- Observabilidade ------------------------------------------------
LOG_LEVEL=info
