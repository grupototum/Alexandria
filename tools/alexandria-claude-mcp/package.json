{
  "name": "@totum-os/alexandria-claude-mcp",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Alexandria MCP Server — Hub de Contexto Semântico do Totum OS (Stdio + SSE, Keycloak, Supabase pgvector).",
  "bin": {
    "alexandria-claude-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:sse": "MCP_TRANSPORT=sse tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@supabase/supabase-js": "^2.45.0",
    "express": "^4.21.1",
    "jose": "^5.9.6",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.10",
    "@vitest/coverage-v8": "^2.1.4",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
